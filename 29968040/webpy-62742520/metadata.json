, (2, -5, -5), (2, -5, -4), (2, -5, -3), (2, -5, -2), (2, -5, -1), (2, -5, 0), (2, -1, -5), (2, -1, -4), (2, -1, -3), (2, -1, -2), (2, -1, -1), (2, -1, 0), (2, 3, -5), (2, 3, -4), (2, 3, -3), (2, 3, -2), (2, 3, -1), (2, 3, 0), (3, -5, 1), (3, -5, 2), (3, -1, 1), (3, -1, 2), (3, 4, 1), (3, 4, 2), (4, -5, 3), (4, -5, 4), (4, -1, 3), (4, -1, 4), (4, 5, 3), (4, 5, 4), (5, -1, 5), (5, 5, 5)]\nmodel1 = [add_color(m) for m in model1]\nmodel2 = [add_color(m) for m in model2]\n\npygame.init()\nscreen = pygame.display.set_mode((800, 600))\nrunning = True\nclock = pygame.time.Clock()\nfont = pygame.font.SysFont(None, 20)\n\nrun_t = time.time()\nwhile running:\n    fps = clock.get_fps()\n    for event in pygame.event.get():\n        if event.type == pygame.QUIT:\n            running = False\n\n    screen.fill(COLOR_BG, (0,0,800,600))\n    # screen.blit(font.render(f'{fps:.2f}', True, 'white'), (10, 10))\n    _t = min(time.time() - run_t, 3) / 3\n    \n    render(screen, model1, _t, 150, 200, 300)\n    render(screen, model2, _t, 150, 600, 300)\n    \n    pygame.display.update()\n    clock.tick(60)\n\npygame.quit()",
