    "xml": "import math\nimport pygame\nimport time\n\n# 修改后的配色方案\nCOLOR_S, COLOR_E = 100, 255  # 更宽的亮度范围\nCOLOR_BG = (20, 20, 40)     # 深蓝色背景\n\ndef ortho(_p, left, right, bottom, top):\n    _x, _y, z = _p\n    new_x = (2 * _x - right - left) / (right - left)\n    new_y = (2 * _y - top - bottom) / (top - bottom)\n    return new_x, new_y, z\n\ndef rotate_x(vector, angle_rad):\n    \"\"\"\n    绕X轴旋转三维向量\n    :param vector: 三维向量 [x, y, z]\n    :param angle_rad: 旋转角度（弧度）\n    :return: 旋转后的新向量 [x', y', z']\n    \"\"\"\n    _x, _y, _z = vector\n    cos_theta = math.cos(angle_rad)\n    sin_theta = math.sin(angle_rad)\n    y_new = _y * cos_theta - _z * sin_theta\n    z_new = _y * sin_theta + _z * cos_theta\n    return [_x, y_new, z_new]\n\ndef rotate_y(vector, angle_rad):\n    \"\"\"\n    绕Y轴旋转三维向量\n    :param vector: 三维向量 [x, y, z]\n    :param angle_rad: 旋转角度（弧度）\n    :return: 旋转后的新向量 [x', y', z']\n    \"\"\"\n    x, y, z = vector\n    cos_theta = math.cos(angle_rad)\n    sin_theta = math.sin(angle_rad)\n    x_new = x * cos_theta + z * sin_theta\n    z_new = -x * sin_theta + z * cos_theta\n    return [x_new, y, z_new]\n\ndef transform(p, t):\n    angle_rad = math.radians(-90 * t)\n    return ortho(rotate_y(rotate_x(p, angle_rad), 0.2 * math.sin(t * math.pi)), -5, 5, -5, 5)\n\ndef render(surface, model, t, scale, tx, ty):\n    t = 4 * t * t * t if t < 0.5 else 1 - pow(-2 * t + 2, 3) / 2\n\n    ps = [(transform(p[0], t), p[1]) for p in model]\n    ps.sort(key=lambda p:p[0][2])\n    for p in ps:\n        pygame.draw.circle(surface, p[1], ((tx+scale*p[0][0]), (ty+scale*p[0][1])), 10)\n\ndef add_color(p):\n    x, y, z = p\n    per_x, per_y, per_z = (x + 5) / 10, (y + 5) / 10, (z + 5) / 10\n    s, e = COLOR_S, COLOR_E\n    return p, (s + (e - s) * per_x, s + (e - s) * per_y, s + (e - s) * per_z)\n\nmodel1 = [(-5, -5, -5), (-5, -5, -4), (-5, -5, -3), (-5, -5, -2), (-5, -5, -1), (-5, -5, 0), (-5, -5, 1), (-5, -5, 2), (-5, -5, 3), (-5, -5, 4), (-5, -5, 5), (-5, -1, -5), (-5, -1, -