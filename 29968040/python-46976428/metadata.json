                   [1.24, -1.02, 1.24],\n                        [0, -1.02, 1.75],\n                        [0, -1.25, 1.5],\n                        [1.5, -1.25, 0],\n                        [1.75, -1.02, 0],\n                        [-1.07, -1.25, 1.07],\n                        [-1.24, -1.02, 1.24],\n                        [-1.75, -1.02, 0],\n                        [-1.5, -1.25, 0],\n                        [-1.07, -1.25, -1.07],\n                        [-1.24, -1.02, -1.24],\n                        [0, -1.02, -1.75],\n                        [0, -1.25, -1.5],\n                        [1.07, -1.25, -1.07],\n                        [1.24, -1.02, -1.24],\n                        [-2.85, 0.4, 0.23],\n                        [-2.52, 0.7, 0.23],\n                        [-2.62, 0.79, 0],\n                        [-3, 0.4, 0],\n                        [-1.55, 0.74, 0.23],\n                        [-1.5, 0.85, 0],\n                        [-2.7, 0.4, 0],\n                        [-2.41, 0.6, 0],\n                        [-1.6, 0.63, 0],\n                        [-2.85, 0.4, -0.23],\n                        [-2.52, 0.7, -0.23],\n                        [-1.55, 0.74, -0.23],\n                        [-1.95, -0.65, 0.23],\n                        [-2.63, -0.15, 0.23],\n                        [-2.73, -0.24, 0],\n                        [-1.9, -0.8, 0],\n                        [-2.54, -0.05, 0],\n                        [-1.95, -0.65, -0.23],\n                        [-2.63, -0.15, -0.23],\n                        [3, 1, 0.19],\n                        [2.54, 0.22, 0.34],\n                        [2.69, 0.04, 0],\n                        [3.3, 1, 0],\n                        [1.7, -0.39, 0.5],\n                        [1.7, -0.8, 0],\n                        [2.7, 1, 0],\n                        [2.39, 0.4, 0],\n                        [1.7, 0.02, 0],\n                        [3, 1, -0.19],\n                        [2.54, 0.22, -0.34],\n                        [1.7, -0