{"from": "adapt", "v": "1626599620892", "name": "Windows11\u521d\u4f53\u9a8c(1)", "xml": "from xes.tool import *\nxopen()", "type": "run", "lang": "python", "id": null, "original_id": 21842520, "version": "offline", "args": [], "code_complete": 1, "removed": 0, "assets": [{"id": "26242386b1788c8ca9a24c5c9520b864", "isSelected": false, "level": 2, "isLeaf": true, "isDir": false, "name": "img1.png", "hide": false, "percentage": 100, "loading": false, "size": 314617, "value": "", "text": "img1.png", "title": "img1.png", "disabled": false, "isExpanded": false, "dataFormat": "jpeg", "ext": "jpeg", "icon": "iconfont iconimg", "svgId": "#iconimg", "type": "oss_file", "originValue": "", "isChange": false, "isActived": false, "sort": 0, "isOpen": false, "assetId": "26242386b1788c8ca9a24c5c9520b864", "md5ext": "26242386b1788c8ca9a24c5c9520b864.jpeg", "mode": "client", "state": "uploadOk", "index": 0, "preClick": false, "preview": true, "editable": false, "lang": "png", "color": "#FFA629", "pid": 0, "path": "C:\\Users\\Hjh91\\\u5b66\u800c\u601d\u76f4\u64ad\\code\\cache\\asset\\21842520"}, {"id": "c5a2f500-4dc5-861e-b3d8-21f52a4db856", "isSelected": false, "level": 2, "isLeaf": true, "isDir": false, "name": "index.html", "hide": false, "percentage": 100, "loading": false, "size": 4325, "value": "<html>\n    <head>\n        <meta charset=\"utf-8\">\n    </head>\n    <body>\n        <div align = \"center\">\n            <h1>Windows11\u521d\u4f53\u9a8c(1): HarmonyOS big sur?</h1>\n        </div>\n        <h4><font color = \"red\">Hello\uff0c\u5927\u5bb6\u597d\uff0c\u6211\u4eec\u53c8\u53cc\u53d2\u53d5\u89c1\u9762\u5566\uff01</font>\u8fd9\u6b21\u4e3a\u5927\u5bb6\u5e26\u6765\u7684\u662f<font color = \"skyblue\">Windows11</font>\u7684\u4f53\u9a8c\uff0c\u5728\u6b63\u5f0f\u7248\u53d1\u5e03\u4e4b\u524d\uff0c\u5148\u8ba9\u5927\u5bb6\u770b\u770b\u600e\u4e48\u6837\uff0c\u503c\u4e0d\u503c\u5f97\u5347\u7ea7\u3002</h4>\n        <div align = \"center\">\n            <img src = \"windows11.png\"width = 600 height= 297/>\n        </div>\n        <h2>\u7b80\u4ecb\uff1a</h2>\n        <h4>\u8fd8\u662f\u5148\u653e\u6570\u636e\uff0c\u4e0d\u60f3\u770b\u7684\u53ef\u4ee5\u76f4\u63a5<font color=\"red\">\u8df3\u8fc7\u4e86</font>\u3002\n        </br>Windows 11\uff0c\u662f\u7531\u5fae\u8f6f\u516c\u53f8\uff08Microsoft\uff09\u5f00\u53d1\u7684\u64cd\u4f5c\u7cfb\u7edf\uff0c\u5e94\u7528\u4e8e\u8ba1\u7b97\u673a\u548c\u5e73\u677f\u7535\u8111\u7b49\u8bbe\u5907\u3002Windows 11\u63d0\u4f9b\u4e86\u8bb8\u591a\u521b\u65b0\uff0c\u4fa7\u91cd\u4e8e\u5728\u7075\u6d3b\u591a\u53d8\u7684\u5168\u65b0\u4f53\u9a8c\u4e2d\u63d0\u9ad8\u6700\u7ec8\u7528\u6237\u7684\u5de5\u4f5c\u6548\u7387\u3002 Windows 11 \u65e8\u5728\u652f\u6301\u5f53\u524d\u7684\u6df7\u5408\u5de5\u4f5c\u73af\u5883\uff0c\u5e76\u5c06\u6210\u4e3a\u6709\u53f2\u4ee5\u6765\u6700\u53ef\u9760\u3001\u5b89\u5168\u3001\u6700\u5177\u8fde\u63a5\u6027\u548c\u6027\u80fd\u6700\u597d\u7684 Windows \u64cd\u4f5c\u7cfb\u7edf\u30022021\u5e746\u670824\u65e5\uff0c\u5fae\u8f6f\u63a8\u51faWindows 11\u64cd\u4f5c\u7cfb\u7edf\uff0c\u8fd9\u662f\u5fae\u8f6f\u8fd16\u5e74\u6765\u9996\u6b21\u63a8\u51fa\u65b0\u7684Windows \u64cd\u4f5c\u7cfb\u7edf\u3002\n        </br><font color = \"green\">\u4e2d\u6587\u540d:\u89c6\u7a97 11</br>\u5916\u6587\u540d:Windows 11</br>\u5f00\u53d1\u5546:\u5fae\u8f6f\uff08Microsoft\uff09</br>\u5f00\u53d1\u4ee3\u53f7:Sun Valley</br>\u6838\u5fc3\u7248\u672c\u53f7Windows NT 10.0</br>\u6e90\u7801\u7c7b\u578b:\u5c01\u95ed\u6e90\u7801\u548c\u5171\u4eab\u6e90\u7801\uff08Windows Driver Frameworks\u73b0\u5df2\u5f00\u6e90\uff09</font>\n        </br>2021\u5e746\u6708\uff0c\u5fae\u8f6f\u5728Build\u5f00\u53d1\u8005\u5927\u4f1a\u4e0a\u5ba3\u5e03\uff0c\u5c06\u4f1a\u57286\u670824\u65e5\u516c\u5e03\u201c\u4e0b\u4e00\u4ee3 Windows\u201d\uff08Next generation of Windows\uff09\uff0cWindows 10 21H2\u592a\u9633\u8c37\u5c06\u4f1a\u547d\u540d\u4e3aWindows 11\u3002\n        </br>\u7f8e\u56fd\u5f53\u5730\u65f6\u95f42021\u5e746\u670824\u65e5\uff0c\u5fae\u8f6f\u63a8\u51fa\u65b0\u7684Windows 11\u7cfb\u7edf\u3002\u8fd9\u662f\u5fae\u8f6f\u8fd16\u5e74\u6765\u9996\u6b21\u63a8\u51fa\u65b0\u7684Windows\u64cd\u4f5c\u7cfb\u7edf\u3002\u6b64\u524d\uff0cWindows 10\u662f\u4e16\u754c\u4e0a\u4f7f\u7528\u6700\u5e7f\u6cdb\u7684PC\u64cd\u4f5c\u7cfb\u7edf\uff0c\u6709\u8d85\u8fc713\u4ebf\u90e8\u8bbe\u5907\u5728\u4f7f\u7528\u3002\u5fae\u8f6f\u9996\u5e2d\u4ea7\u54c1\u5b98\u5e15\u8bfa\u65af\u00b7\u6f58\u4e43\uff08Panos Panay\uff09\u5c06Windows 11\u7cfb\u7edf\u63cf\u8ff0\u4e3a\u201c\u8ba9\u4f60\u66f4\u63a5\u8fd1\u81ea\u5df1\u6240\u7231\u4e4b\u7269\u7684Windows\u201d \u3002\n        </br>\u7f8e\u56fd\u65f6\u95f46\u670828\u65e5\uff0c\u5fae\u8f6f\u63a8\u9001 Insider Preview \u9884\u89c8\u7248\uff0c\u4e4b\u540e\u5728\u5723\u8bde\u8282\u671f\u95f4\u63a8\u51fa\u6b63\u5f0f\u7248\u4e14\u57282022\u5e74\u652f\u6301\u5347\u7ea7</h4>\n        <h2>\u6539\u53d8</h2>\n        <h4>\u4f3c\u4e4e\u5f88\u591a\u4eba\u5f88\u5947\u602a\uff0c\u5fae\u8f6f\u4e0d\u662f\u8bf4Windows10\u662f\u6700\u540e\u4e00\u4ee3\u64cd\u4f5c\u7cfb\u7edf\u4e86\u5417\uff0c\u4e3a\u5565\u53c8\u53d1\u5e03\u4e86\u4e00\u4e2awin11\uff1f</br>\n        \u5176\u5b9e\u4f60\u8981\u7ec6\u770b\u5c31\u4f1a\u53d1\u73b0\u8fd9\u5176\u5b9e\u5c31\u662f\u4e00\u4e2a\u82f9\u679c\u7f8e\u5986\u7684\u9e3f\u8499\u7cfb\u7edf\uff01</br>\n        \u6bd4\u5982\u8fd9\u4e2a\u5706\u89d2\u7684\u5f00\u59cb\u83dc\u5355\uff1a</h4>\n        <div align = \"center\">\n            <img src = \"win11\u5f00\u59cb.png\"width = 800 height= 600/>\n        </div>\n        <h4>\u8fd8\u6709\u8fd9\u4e2a\u5c0f\u7ec4\u4ef6\uff1a</h4>\n        <div align = \"center\">\n            <img src = \"win11\u5c0f\u7ec4\u4ef6.png\"width = 528 height= 297/>\n        </div>\n        <h4>\u8ba9macOS\u7528\u6237\u83ab\u540d\u611f\u5230\u719f\u6089\u3002\u751a\u81f3\u8fd8\u6709\u4eba\u8bf4macOS\u572810\u505c\u7559\uff0c\u7136\u540ewindows\u4e5f\u8ddf\u7740\u505c\u7559\uff0c\u968f\u540emacOS\u53d1\u5e03\u4e8611.0\uff08big sur\uff09Windows\u4e5f\u5c31\u7d27\u8ddf\u7740\u53d1\u5e03\u4e86Windows11\uff0c\u771f\u662f\u65e0\u8bed\uff0c\u5fae\u8f6f\u4ec0\u4e48\u65f6\u5019\u5c31\u4e0d\u6284\u88admac\u4e86\u2026\u2026\u4e0d\u8fc7\u8fd9\u6b21Windows11\u53ef\u662f\u5e26\u7740\u8fdc\u5927\u62a5\u590d\u6765\u7684\uff0c\u9996\u5148\u6539\u53d8\u4e86\u63d0\u793a\u97f3\uff0c\u4e0b\u9762\u7ed9\u5927\u5bb6\u542c\u51e0\u4e2a\u3002</h4>\n        <audio controls=\"controls\" style=\"width:100%\">\n            <source src=\"\u5f55\u97f3.mp3\">\n        </audio>\n        <audio controls=\"controls\" style=\"width:100%\">\n            <source src=\"\u5f55\u97f32.mp3\">\n        </audio>\n        <audio controls=\"controls\" style=\"width:100%\">\n            <source src=\"\u5f55\u97f33.mp3\">\n        </audio>\n        <h4>\u5176\u6b21\u6539\u53d8\u4e86UI\uff0c\u5c06\u539f\u6765\u7684\u65b9\u89d2\u77e9\u5f62\u6539\u4e3a\u4e86\u66f4\u52a0\u548c\u8c10<s>\uff08\u7b26\u5408macOS big sur\uff09</s>\u7684\u5706\u89d2\u77e9\u5f62\u3002</br>\n        \u6700\u540e\u4e5f\u662f\u6700\u91cd\u8981\u7684\u5c31\u662f\u539f\u751f\u652f\u6301android\u5e94\u7528\uff01\uff01\uff01\u5f53\u7136\u6309\u7167\u4ee5\u5f80\u7684\u89c4\u77e9\uff0cbeta\u7248\u672c\u5e76\u4e0d\u652f\u6301\uff0c\u5fae\u8f6f\u53c8\u2122<s>\u653e\u9e3d\u5b50</s>\u5f00PPT\u53d1\u5e03\u4f1a\u3002\u9c81\u5927\u5e08\u624b\u673a\u6a21\u62df\u5668\u5371\uff01\u5f53\u7136\u5fae\u8f6f\u53c8\u7559\u4e86\u4e00\u624b\uff0c\u53ea\u6709\u5728Microsoft Store\u91cc\u4e0b\u8f7d\u7684\u5e94\u7528\u624d\u53ef\u4ee5\u8fd0\u884c\u3002</br>\n        \u8fde\u5fae\u8f6f\u90fd\u5f00\u59cb\u4e07\u7269\u4e92\u8054\u7684\u4eca\u5929\uff0cHarmonyOS\u3001M1\u82af\u7247 \u5371\uff01\u5f53\u7136\u8fd9\u4e00\u5207\u7684<s>\u5e55\u540e\u9ed1\u624b</s>\u652f\u6301\u8005\u5c31\u662f\u524d\u4e0d\u4e45\u548c\u82f9\u679c\u63a5\u4e86\u6101\u7684<s>\u7259\u818f\u5382</s>Intel\u3002\u7a81\u7136\u611f\u89c9AMD NO\uff01</h4>\n        <h4><font color = \"red\">\u4eca\u5929\u5c31\u5230\u8fd9\u91cc\u5427\uff0c\u5177\u4f53\u7684\u4f7f\u7528\u4f53\u9a8c\u6211\u4f1a\u653e\u5230\u4e0b\u4e00\u7bc7\u8bb2\u89e3\u3002\u4f60\u7684\u4e09\u8fde\u5c31\u662f\u6211\u6700\u5927\u7684\u52a8\u529b\uff0c\u6211\u662f\u80e1\u9526\u8f89\uff0c\u6211\u4eec\u4e0b\u671f\u518d\u89c1\uff01</font></h4>\n    </body>\n</html>", "text": "index.html", "title": "index.html", "disabled": false, "isExpanded": true, "dataFormat": "html", "ext": "html", "icon": "iconfont iconhtml", "svgId": "#iconhtml", "type": "local_file", "originValue": "<html>\n    <head>\n        <meta charset=\"utf-8\">\n    </head>\n    <body>\n        <div align = \"center\">\n            <h1>Windows11\u521d\u4f53\u9a8c(1): HarmonyOS big sur?</h1>\n        </div>\n        <h4><font color = \"red\">Hello\uff0c\u5927\u5bb6\u597d\uff0c\u6211\u4eec\u53c8\u53cc\u53d2\u53d5\u89c1\u9762\u5566\uff01</font>\u8fd9\u6b21\u4e3a\u5927\u5bb6\u5e26\u6765\u7684\u662f<font color = \"skyblue\">Windows11</font>\u7684\u4f53\u9a8c\uff0c\u5728\u6b63\u5f0f\u7248\u53d1\u5e03\u4e4b\u524d\uff0c\u5148\u8ba9\u5927\u5bb6\u770b\u770b\u600e\u4e48\u6837\uff0c\u503c\u4e0d\u503c\u5f97\u5347\u7ea7\u3002</h4>\n        <div align = \"center\">\n            <img src = \"windows11.png\"width = 600 height= 297/>\n        </div>\n        <h2>\u7b80\u4ecb\uff1a</h2>\n        <h4>\u8fd8\u662f\u5148\u653e\u6570\u636e\uff0c\u4e0d\u60f3\u770b\u7684\u53ef\u4ee5\u76f4\u63a5<font color=\"red\">\u8df3\u8fc7\u4e86</font>\u3002\n        </br>Windows 11\uff0c\u662f\u7531\u5fae\u8f6f\u516c\u53f8\uff08Microsoft\uff09\u5f00\u53d1\u7684\u64cd\u4f5c\u7cfb\u7edf\uff0c\u5e94\u7528\u4e8e\u8ba1\u7b97\u673a\u548c\u5e73\u677f\u7535\u8111\u7b49\u8bbe\u5907\u3002Windows 11\u63d0\u4f9b\u4e86\u8bb8\u591a\u521b\u65b0\uff0c\u4fa7\u91cd\u4e8e\u5728\u7075\u6d3b\u591a\u53d8\u7684\u5168\u65b0\u4f53\u9a8c\u4e2d\u63d0\u9ad8\u6700\u7ec8\u7528\u6237\u7684\u5de5\u4f5c\u6548\u7387\u3002 Windows 11 \u65e8\u5728\u652f\u6301\u5f53\u524d\u7684\u6df7\u5408\u5de5\u4f5c\u73af\u5883\uff0c\u5e76\u5c06\u6210\u4e3a\u6709\u53f2\u4ee5\u6765\u6700\u53ef\u9760\u3001\u5b89\u5168\u3001\u6700\u5177\u8fde\u63a5\u6027\u548c\u6027\u80fd\u6700\u597d\u7684 Windows \u64cd\u4f5c\u7cfb\u7edf\u30022021\u5e746\u670824\u65e5\uff0c\u5fae\u8f6f\u63a8\u51faWindows 11\u64cd\u4f5c\u7cfb\u7edf\uff0c\u8fd9\u662f\u5fae\u8f6f\u8fd16\u5e74\u6765\u9996\u6b21\u63a8\u51fa\u65b0\u7684Windows \u64cd\u4f5c\u7cfb\u7edf\u3002\n        </br><font color = \"green\">\u4e2d\u6587\u540d:\u89c6\u7a97 11</br>\u5916\u6587\u540d:Windows 11</br>\u5f00\u53d1\u5546:\u5fae\u8f6f\uff08Microsoft\uff09</br>\u5f00\u53d1\u4ee3\u53f7:Sun Valley</br>\u6838\u5fc3\u7248\u672c\u53f7Windows NT 10.0</br>\u6e90\u7801\u7c7b\u578b:\u5c01\u95ed\u6e90\u7801\u548c\u5171\u4eab\u6e90\u7801\uff08Windows Driver Frameworks\u73b0\u5df2\u5f00\u6e90\uff09</font>\n        </br>2021\u5e746\u6708\uff0c\u5fae\u8f6f\u5728Build\u5f00\u53d1\u8005\u5927\u4f1a\u4e0a\u5ba3\u5e03\uff0c\u5c06\u4f1a\u57286\u670824\u65e5\u516c\u5e03\u201c\u4e0b\u4e00\u4ee3 Windows\u201d\uff08Next generation of Windows\uff09\uff0cWindows 10 21H2\u592a\u9633\u8c37\u5c06\u4f1a\u547d\u540d\u4e3aWindows 11\u3002\n        </br>\u7f8e\u56fd\u5f53\u5730\u65f6\u95f42021\u5e746\u670824\u65e5\uff0c\u5fae\u8f6f\u63a8\u51fa\u65b0\u7684Windows 11\u7cfb\u7edf\u3002\u8fd9\u662f\u5fae\u8f6f\u8fd16\u5e74\u6765\u9996\u6b21\u63a8\u51fa\u65b0\u7684Windows\u64cd\u4f5c\u7cfb\u7edf\u3002\u6b64\u524d\uff0cWindows 10\u662f\u4e16\u754c\u4e0a\u4f7f\u7528\u6700\u5e7f\u6cdb\u7684PC\u64cd\u4f5c\u7cfb\u7edf\uff0c\u6709\u8d85\u8fc713\u4ebf\u90e8\u8bbe\u5907\u5728\u4f7f\u7528\u3002\u5fae\u8f6f\u9996\u5e2d\u4ea7\u54c1\u5b98\u5e15\u8bfa\u65af\u00b7\u6f58\u4e43\uff08Panos Panay\uff09\u5c06Windows 11\u7cfb\u7edf\u63cf\u8ff0\u4e3a\u201c\u8ba9\u4f60\u66f4\u63a5\u8fd1\u81ea\u5df1\u6240\u7231\u4e4b\u7269\u7684Windows\u201d \u3002\n        </br>\u7f8e\u56fd\u65f6\u95f46\u670828\u65e5\uff0c\u5fae\u8f6f\u63a8\u9001 Insider Preview \u9884\u89c8\u7248\uff0c\u4e4b\u540e\u5728\u5723\u8bde\u8282\u671f\u95f4\u63a8\u51fa\u6b63\u5f0f\u7248\u4e14\u57282022\u5e74\u652f\u6301\u5347\u7ea7</h4>\n        <h2>\u6539\u53d8</h2>\n        <h4>\u4f3c\u4e4e\u5f88\u591a\u4eba\u5f88\u5947\u602a\uff0c\u5fae\u8f6f\u4e0d\u662f\u8bf4Windows10\u662f\u6700\u540e\u4e00\u4ee3\u64cd\u4f5c\u7cfb\u7edf\u4e86\u5417\uff0c\u4e3a\u5565\u53c8\u53d1\u5e03\u4e86\u4e00\u4e2awin11\uff1f</br>\n        \u5176\u5b9e\u4f60\u8981\u7ec6\u770b\u5c31\u4f1a\u53d1\u73b0\u8fd9\u5176\u5b9e\u5c31\u662f\u4e00\u4e2a\u82f9\u679c\u7f8e\u5986\u7684\u9e3f\u8499\u7cfb\u7edf\uff01</br>\n        \u6bd4\u5982\u8fd9\u4e2a\u5706\u89d2\u7684\u5f00\u59cb\u83dc\u5355\uff1a</h4>\n        <div align = \"center\">\n            <img src = \"win11\u5f00\u59cb.png\"width = 800 height= 600/>\n        </div>\n        <h4>\u8fd8\u6709\u8fd9\u4e2a\u5c0f\u7ec4\u4ef6\uff1a</h4>\n        <div align = \"center\">\n            <img src = \"win11\u5c0f\u7ec4\u4ef6.png\"width = 528 height= 297/>\n        </div>\n        <h4>\u8ba9macOS\u7528\u6237\u83ab\u540d\u611f\u5230\u719f\u6089\u3002\u751a\u81f3\u8fd8\u6709\u4eba\u8bf4macOS\u572810\u505c\u7559\uff0c\u7136\u540ewindows\u4e5f\u8ddf\u7740\u505c\u7559\uff0c\u968f\u540emacOS\u53d1\u5e03\u4e8611.0\uff08big sur\uff09Windows\u4e5f\u5c31\u7d27\u8ddf\u7740\u53d1\u5e03\u4e86Windows11\uff0c\u771f\u662f\u65e0\u8bed\uff0c\u5fae\u8f6f\u4ec0\u4e48\u65f6\u5019\u5c31\u4e0d\u6284\u88admac\u4e86\u2026\u2026\u4e0d\u8fc7\u8fd9\u6b21Windows11\u53ef\u662f\u5e26\u7740\u8fdc\u5927\u62a5\u590d\u6765\u7684\uff0c\u9996\u5148\u6539\u53d8\u4e86\u63d0\u793a\u97f3\uff0c\u4e0b\u9762\u7ed9\u5927\u5bb6\u542c\u51e0\u4e2a\u3002</h4>\n        <audio controls=\"controls\" style=\"width:100%\">\n            <source src=\"\u5f55\u97f3.mp3\">\n        </audio>\n        <audio controls=\"controls\" style=\"width:100%\">\n            <source src=\"\u5f55\u97f32.mp3\">\n        </audio>\n        <audio controls=\"controls\" style=\"width:100%\">\n            <source src=\"\u5f55\u97f33.mp3\">\n        </audio>\n        <h4>\u5176\u6b21\u6539\u53d8\u4e86UI\uff0c\u5c06\u539f\u6765\u7684\u65b9\u89d2\u77e9\u5f62\u6539\u4e3a\u4e86\u66f4\u52a0\u548c\u8c10<s>\uff08\u7b26\u5408macOS big sur\uff09</s>\u7684\u5706\u89d2\u77e9\u5f62\u3002</br>\n        \u6700\u540e\u4e5f\u662f\u6700\u91cd\u8981\u7684\u5c31\u662f\u539f\u751f\u652f\u6301android\u5e94\u7528\uff01\uff01\uff01\u5f53\u7136\u6309\u7167\u4ee5\u5f80\u7684\u89c4\u77e9\uff0cbeta\u7248\u672c\u5e76\u4e0d\u652f\u6301\uff0c\u5fae\u8f6f\u53c8\u2122<s>\u653e\u9e3d\u5b50</s>\u5f00PPT\u53d1\u5e03\u4f1a\u3002\u9c81\u5927\u5e08\u624b\u673a\u6a21\u62df\u5668\u5371\uff01\u5f53\u7136\u5fae\u8f6f\u53c8\u7559\u4e86\u4e00\u624b\uff0c\u53ea\u6709\u5728Microsoft Store\u91cc\u4e0b\u8f7d\u7684\u5e94\u7528\u624d\u53ef\u4ee5\u8fd0\u884c\u3002</br>\n        \u8fde\u5fae\u8f6f\u90fd\u5f00\u59cb\u4e07\u7269\u4e92\u8054\u7684\u4eca\u5929\uff0cHarmonyOS\u3001M1\u82af\u7247 \u5371\uff01\u5f53\u7136\u8fd9\u4e00\u5207\u7684<s>\u5e55\u540e\u9ed1\u624b</s>\u652f\u6301\u8005\u5c31\u662f\u524d\u4e0d\u4e45\u548c\u82f9\u679c\u63a5\u4e86\u6101\u7684<s>\u7259\u818f\u5382</s>Intel\u3002\u7a81\u7136\u611f\u89c9AMD NO\uff01</h4>\n        <h4><font color = \"red\">\u4eca\u5929\u5c31\u5230\u8fd9\u91cc\u5427\uff0c\u5177\u4f53\u7684\u4f7f\u7528\u4f53\u9a8c\u6211\u4f1a\u653e\u5230\u4e0b\u4e00\u7bc7\u8bb2\u89e3\u3002\u4f60\u7684\u4e09\u8fde\u5c31\u662f\u6211\u6700\u5927\u7684\u52a8\u529b\uff0c\u6211\u662f\u80e1\u9526\u8f89\uff0c\u6211\u4eec\u4e0b\u671f\u518d\u89c1\uff01</font></h4>\n    </body>\n</html>", "isChange": true, "isActived": false, "sort": 0, "isOpen": true, "preview": true, "editable": true, "lang": "html", "color": "#FC490B", "pid": 0, "operation": "uploadOk", "state": "uploadOk", "md5ext": "aa7bbc16f39888e9b2dd5bca8c43d066.html", "assetId": "aa7bbc16f39888e9b2dd5bca8c43d066", "preClick": false}, {"id": "98c1293a-b624-a850-bdd3-95d72883e619", "isSelected": false, "level": 2, "isLeaf": true, "isDir": false, "name": "windows11.png", "hide": false, "percentage": 100, "loading": false, "size": 1692662, "value": "", "text": "windows11.png", "title"