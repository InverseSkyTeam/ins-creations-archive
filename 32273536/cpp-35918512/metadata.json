    "xml": "#include <iostream>\n#include <iomanip>\nusing namespace std;\n\nvoid safe_flush(FILE *fp)\n{\nint ch;\nwhile( (ch = fgetc(fp)) != EOF && ch != '\\n' );\n}\nint run()\n{\n    long double sum=1; \n    unsigned long int total;\n    short su;\n    cout<<\"输入阶乘次数：\";\n    su=scanf(\"%ld\",&total);\n    if(su==1)\n    {\n        for(long i=1;i<=total;i++)\n        {\n            sum*=i;\n        }\n    }\n    else\n    {\n        cout<<\"键入的值无效\"<<endl;\n        return 1;\n    }\n    \n    cout<<fixed<<sum<<endl;\n    return 0;\n}\nint main()\n{\n    run();\n    safe_flush(stdin);\n    main();\n    return 0;\n}",
