    "xml": "from turtle import*\nspeed(0)\nwi=width\nfd=forward\nlt=left\nrt=right\nc=clear\ns=stamp\ng=goto\nhideturtle()\ndef h(a=10,b=10,c=20):\n    pendown()\n    w=c\n    for i in range(a):\n        wi(w)\n        fd(10)\n        w=w-1\n    for i in range(a):\n        wi(w)\n        fd(10)\n        w=w+1\n    penup()\ndef s(a=20,b=20,c=1,d=90,e=1):\n    if c==1:\n        w=0\n        rt(d)\n        penup()\n        for i in range(a):\n            wi(w)\n            fd(10)\n            w=w+e\n            pendown()\n    if c==2:\n        w=b\n        rt(d)\n        penup()\n        for i in range(a):\n            wi(w)\n            fd(10)\n            w=w-e\n            pendown()\n    lt(d)\n    penup()\npenup()\ng(100,10)\ns(7,35,2,-135,7)\ng(0,0)\ns(7,35,1,135,7)\ng(-10,-20)\nh()\ns(5,25,2,135,5)\ng(-30,-100)\nh()\ng(80,-60)\ns(20,30,2)\ng(70,-100)\ns(15,20,2,135,1)\ng(70,-100)\ns(15,20,1,40,20/15)\ns(4,20,2,0,5)\nclear()\ng(40,20)\nh(6)\ng(0,-40)\nh(10)\ng(80,-30)\ns(8,20,1,120,2.5)\ns(6,20,2,150,2)\ng(130,-30)\ns(12,20,1,90,20/12)\ns(2,20,2,45)\ns(8,20,2,0,1.5)\ns(8,20,2,-90,20/8)\nclear()\ng(-100,10)\ns(15,20,2,90)\ng(-100,0)\nh(4,10,10)\ns(2,15,2,45,0)\nlt(90)\nfd(10)\nrt(90)\ns(15,20,2,95)\ng(-100,-70)\nh(4,10,10)\ng(-95,-140)\nh(4,10,10)\ng(20,50)\ns(15,20,2,90,0)\ns(3,20,2,100)\ns(8,17,2,110,20/8)\ng(20,40)\nh(5,1,10)\ns(2,20,2,45,0)\nfd(-5)\nlt(90)\nfd(10)\nrt(90)\ns(25,25,2,90,0)\ns(5,20,2,-135,4)\ng(20,-20)\nh(5,1,10)\ng(20,-75)\nh(5,1,10)",
