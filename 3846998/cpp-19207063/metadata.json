    "xml": "#include <bits/stdc++.h>\nusing namespace std;\nint dcsl(int a1,int a2,int c){\n    int ans,a;\n    a=(a2-a1)/c+1;\n    ans=(a1+a2)*a/2;\n    return ans;\n}\nint main()\n{\n    int a1,a2,c;\n    cout<<\"首项：\";\n    cin>>a1;\n    cout<<\"末项：\";\n    cin>>a2;\n    cout<<\"公差：\";\n    cin>>c;\n    cout<<\"等差数列的总和是：\"<<dcsl(a1,a2,c);\n    return 0;\n}",
