    "xml": "from turtle import*\ndef Dshu(a,b,c,d,e):\n    t=Turtle()\n    t.penup()\n    t.goto(a,b)\n    t.pendown()\n    t.goto(a,b-c)\n    t.goto(a+d,b-c+d)\n    t.goto(a+d,b-e*2-d)\n    t.goto(a+d+e,b-d-e)\n    t.goto(a,b)\ndef Dheng(a,b,c,d,e):\n    t=Turtle()\n    t.penup()\n    t.goto(a,b)\n    t.pendown()\n    t.goto(a+c-e*2,b)\n    t.goto(a+c-e,b+e)\n    t.goto(a+c+d,b-d)\n    t.goto(a+d,b-d)\n    t.goto(a,b)\nDshu(-50,-50,200,10,5)\nDheng(-300,-200,200,5,20)",
