    "xml": "#include <iostream>\n#include <string>\nusing namespace std;\n\nint main()\n{\n    int a;\n    string b;\n    cout<<\"大写转小写输入1，小写转大写输入2：\";\n    cin>>a;\n    if(a==1){\n        cout<<\"请输入字符串：\";\n        cin>>b;\n        for(int i=0;i<b.size();i++){\n            if(b[i]<='Z' and b[i]>='A') b[i]=b[i]+32;\n        }\n    }\n    else if(a==2){\n        cout<<\"请输入字符串：\";\n        cin>>b;\n        for(int i=0;i<b.size();i++){\n            if(b[i]<='z' and b[i]>='a') b[i]=b[i]-32;\n        }\n    }\n    cout<<endl<<\"结果是：\"<<b;\n    return 0;\n}",
