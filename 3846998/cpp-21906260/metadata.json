    "xml": "#include <iostream>\nusing namespace std;\nbool bin[2000000001]={};\nint main()\n{\n    system(\"clear\");\n    cout<<\"桶排序，支持20亿以内整数，自动去重（输出时需要一些时间，请耐心等待）\\n\";\n    cout<<\"请输入需要排序的数列长度：\";\n    int a;\n    cin>>a;\n    cout<<\"请输入这个数列：\";\n    for(int i=0;i<a;i++){int ls;cin>>ls;bin[ls]=1;}\n    cout<<\"结果是：\";\n    for(int i=0;i<2000000001;i++) if(bin[i]) cout<<i<<' ';\n    return 0;\n}",
