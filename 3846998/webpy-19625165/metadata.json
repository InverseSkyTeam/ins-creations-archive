    "xml": "from turtle import*\nfrom time import*\nt=Turtle()\nt.speed(0)\nt.hideturtle()\ndef c(a,b,c,d,e):\n    if e==1:\n        t.goto(c,d)\n        t.pendown()\n        t.begin_fill()\n        for i in range(a):\n            t.fd(b)\n            t.left(360/a)\n        t.end_fill()\n    elif e==0:\n        t.goto(c,d)\n        t.pendown()\n        for i in range(a):\n            t.fd(b)\n            t.left(360/a)\na=200\nfor i in range(200):\n    c(3,a,0,0,0)\n    t.left(a)\n    a=a-1\nsleep(5)\nt.clear()\na=200\nfor i in range(200):\n    c(3,a,0,0,0)\n    t.left(18)\n    a=a-1",
