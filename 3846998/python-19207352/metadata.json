    "xml": "def prime(a):\n    if a==1 or a==0:\n        return(False)\n    for i in range(2,a):\n        if a%i==0 and a/i!=1:\n            return(False)\n    return(True)\nprint(prime(int(input(\"请输入要判断是不是质数的数：\"))))",
