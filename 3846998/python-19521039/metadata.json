    "xml": "a=int(input('第一个数:'))\nb=int(input('第二个数:'))\nc=a*b\nd=1\nfor i in range(2,a*b):\n    while 1:\n        if a%i==0 and b%i==0:\n            d=d*i\n            c=c/i\n            a=a/i\n            b=b/i\n        else:\n            break\nprint('最小公倍数是',c,'最大公因数是',d)",
