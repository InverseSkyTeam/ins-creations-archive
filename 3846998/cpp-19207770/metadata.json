    "xml": "#include<bits/stdc++.h>\nusing namespace std;\nstring in(string s,string t){\n\tint c=t.length();\n\tif(c>s.size()){\n\t\treturn \"no\";\n\t}\n\telse{\n\t\tfor(int i=0;i<s.size();i++){\n\t\t\tif(s.substr(i,t.length())==t){\n\t\t\t\treturn \"yes\";\n\t\t\t}\n\t\t}\n\treturn \"no\";\n\t}\n}\nint main()\n{\n    string s,t;\n    cin>>s>>t;\n    cout<<in(s,t);\n\treturn 0;\n}",
