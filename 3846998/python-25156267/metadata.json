    "xml": "print(\"计算两点之间的距离\")\ndef jl(a,b):\n    try:\n        x1,y1=a\n        x2,y2=b\n        return(((x1-x2)**2+(y1-y2)**2)**0.5)\n    except:\n        return(\"错误！\")\ntry:\n    print(\"点1到点2的距离是：\",jl(eval(input(\"请输入点1的坐标（格式是x,y）：\")),eval(input(\"请输入点2的坐标：\"))))\nexcept:\n    pass",
