    "xml": "#include <iostream>\nusing namespace std;\nint prime(int a){\n    int b=1;\n    if(a==1||a==0) return 0;\n    for(int i=2;i<a;i++){\n        if(a%i==0&&a/i!=1){\n            b=0;\n            return b;\n        }\n    }\n    return b;\n}\nint main()\n{\n    int a;\n    cout<<\"请输入要判断是不是质数的数\";\n    cin>>a;\n    cout<<prime(a);\n}",
