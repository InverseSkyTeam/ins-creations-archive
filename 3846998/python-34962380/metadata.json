    "thumbnail": "https://static0.xesimg.com/talcode/assets/py/default-python-thumbnail.png",
    "xml": "print('''{\n    /*\n    这是一个dfs求8的全排列的integer3程序\n    */\n    import builtin;\n    var n=8,answer=[0,0,0,0,0,0,0,0],visit=[0,0,0,0,0,0,0,0];\n    func sleep(a){//sleep函数\n        var begin=time();\n        while time()-begin<a;\n    }\n    func dfs(k){//学过c++的应该知道dfs怎么写\n        if k==n{\n            foreach i in answer print(i,\" \");\n            println();\n            sleep(0.001);//防止输出超长\n        }\n        for var i=0;i<n;i=i+1 if visit[i]==0{\n            visit[i]=1;\n            answer[k]=i+1;\n            dfs(k+1);\n            answer[k]=0;\n            visit[i]=0;\n        }\n    }\n    dfs(0);\n}''')",
