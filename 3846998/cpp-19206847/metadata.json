    "xml": "#include <iostream>\n#include <bits/stdc++.h>\nusing namespace std;\nint main()\n{\n    cout<<\"本计算器支持加（+）、减（-）、乘（*或x）、取余（%）、和整除（/,会保留整数）,且需要输入英文字符\"<<endl;\n    cout<<\"请直接输入一个只有一个运算符号的算式：\";\n    int a,b;\n    char c;\n    cin>>a>>c>>b;\n    if(c=='+') cout<<a+b;\n\telse if(c=='-') cout<<a-b;\n\telse if(c=='*') cout<<a*b;\n\telse if(c=='/') cout<<a/b;\n\telse if(c=='%') cout<<a%b;\n\telse cout<<\"输入错误\";\n    return 0;\n}",
