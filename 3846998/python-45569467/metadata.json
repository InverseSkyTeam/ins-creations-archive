    "xml": "import time\n\n\ndef fn(n: int):\n    if n == 0:\n        return None\n    print(n)\n    time.sleep(0.001)\n    return fn(n - 1)\n    \n    \ndef get_res(fn, *args):\n    ret = fn(*args)\n    while callable(ret):\n        ret = ret()\n    return ret\n\n\ndef better_fn(n: int):\n    if n == 0:\n        return None\n    print(n)\n    time.sleep(0.001)\n    return lambda: better_fn(n - 1)\n\n\nget_res(better_fn, 10000)\n",
