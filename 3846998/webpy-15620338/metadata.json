    "xml": "from turtle import*\ndef Dshu(a,b,c,d,e):\n    t=Turtle()\n    t.penup()\n    t.goto(a,b)\n    t.pendown()\n    t.goto(a,b-c)\n    t.goto(a+d,b-c+d)\n    t.goto(a+d,b-e*2-d)\n    t.goto(a+d+e,b-d-e)\n    t.goto(a,b)\ndef Dheng(a,b,c,d,e):\n    t=Turtle()\n    t.penup()\n    t.goto(a,b)\n    t.pendown()\n    t.goto(a+c-e*2,b)\n    t.goto(a+c-e,b+e)\n    t.goto(a+c+d,b-d)\n    t.goto(a+d,b-d)\n    t.goto(a,b)\ndef Dzuodian(a,b,c):\n    t=Turtle()\n    t.penup()\n    t.goto(a,b)\n    t.pendown()\n    t.rt(45)\n    t.fd(c)\n    t.left(150)\n    t.fd(c/3)\n    t.goto(a,b)\nDshu(-40,-50,200,20,5)\nDheng(-110,-130,150,10,20)\nDzuodian(0,300,200)",
