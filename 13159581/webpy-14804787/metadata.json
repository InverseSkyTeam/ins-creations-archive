    "xml": "from turtle import *\n#1、补充for循环语句，让小鱼游动起来\n#2、尝试修改代码，换成其他背景、或生物\n\n#修改代码，尝试其他海洋背景，注意文件名参考左侧。\nsc = Screen()\na = Screen()\nc = Screen()\ne = Screen()\ng = Screen()\nsc.bgpic(\"sea.png\")\nsc.register_shape(\"fish5.png\")\na.register_shape(\"fish1.png\")\ne.register_shape(\"潜水艇1.png\")\ng.register_shape(\"乌龟1.png\")\nc.register_shape(\"扇贝.png\")\nsc.register_shape(\"fish6.png\")\na.register_shape(\"fish2.png\")\ne.register_shape(\"潜水艇2.png\")\ng.register_shape(\"乌龟2.png\")\nt = Turtle()\nb = Turtle()\nd = Turtle()\nf = Turtle()\nh = Turtle()\nt.penup()\nb.penup()\nd.penup()\nf.penup()\nh.penup()\nt.goto(-500,0)\nb.goto(-500,100)\nd.goto(0,-350)\nf.goto(-500,-100)\nh.goto(-500,-50)\nd.shape(\"扇贝.png\")\n#在第17行补充for循环语句\n#修改代码，尝试其他鱼类素材，注意文件名参考左侧。\nfor i in range(100):\n    t.shape(\"fish5.png\")\n    b.shape(\"fish1.png\")\n    f.shape(\"潜水艇1.png\")\n    h.shape(\"乌龟1.png\")\n    t.forward(1000)\n    b.forward(1000)\n    f.forward(1000)\n    h.forward(1000)\n    t.right(180)\n    b.right(180)\n    f.right(180)\n    h.right(180)\n    t.shape(\"fish6.png\")\n    b.shape(\"fish2.png\")\n    f.shape(\"潜水艇2.png\")\n    h.shape(\"乌龟2.png\")\n    t.forward(1000)\n    b.forward(1000)\n    f.forward(1000)\n    h.forward(1000)\n    t.right(180)\n    b.right(180)\n    f.right(180)\n    h.right(180)\n",
