    "xml": "#补充完整第25行代码，设计获得课堂称号的规则吧！\n\nprint(\"请小极客设计获得课堂称号的规则吧！\")\n\nnum = int(input(\"请输入你答对的题目数量：\"))\n\n# --------------------\n#|  数量   |   称号   |\n#|--------------------|\n#|    1    |   学萌   |\n#|    2    |   学童   |\n#|  3到4   |   学徒   |\n#|  5到6   |   荣耀   |\n#|  7到9   |   至尊   |\n#|  超过10 |  未来星  |\n# --------------------\nif num == 1:\n    print(\"恭喜你获得学萌称号！\")\nelif num == 2:\n    print(\"恭喜你获得学童称号！\")\nelif num < 5:\n    print(\"恭喜你获得学徒称号！\")\n#作答区域。\n#补充完整第25行代码，当答题数量num在5到6之间时，获得荣耀称号。\nelif num < 7:\n    print(\"恭喜你获得荣耀称号！\")\nelif num < 10:\n    print(\"恭喜你获得至尊称号！\")\nelse:\n    print(\"恭喜你成为本节课的未来星！\")",
