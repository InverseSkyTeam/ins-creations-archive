    "xml": "from random import *\nfrom easygui import *\na = randint(1,10)\nmsg = \"不妨猜一下陈锦奕心里想的是哪个数字(1~10)\"\ntitle = \"数字小游戏\"\nguess = integerbox(msg,title,lowerbound=1,upperbound=10)\nwhile True:\n    if guess == a:\n        msgbox(\"你怎么知道的？\")\n        break\n    if guess > a:\n        msgbox(\"猜大了！\")\n    if guess < a:\n        msgbox(\"猜小了！\")\n    guess = integerbox(msg,title,lowerbound=1,upperbound=10)\nmsgbox(\"游戏结束,不玩啦^_^\")",
