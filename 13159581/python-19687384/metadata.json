    "xml": "# 现在学习编程的有可多、小红、小明三名同学。\n# 运行程序，并将你的学习编程的几位好朋友拉入群中；\n# 小红由于生病退出了学习群，请运行程序请她出群。\n# 按下其他按键时，退出程序\n\nfriends= [\"可多\",\"小红\",\"小明\"]\nwhile True:\n    choice = input(\"加好友进群请按“+”，请人出群请按“-”，完成请按其他键：\")\n    if choice == \"+\":\n        c = input(\"进群好友姓名：\")\n        friends.append(c)\n        print('当前群内成员：',friends)\n#请你在下面补充程序，实现请人退群的功能\n    if choice == \"+\":\n        c = input(\"退群好友姓名：\")\n        friends.remove(c)\n    \n    \n    if choice != \"+\" and choice != \"-\":\n        print('当前群内成员：',friends)\n        break",
