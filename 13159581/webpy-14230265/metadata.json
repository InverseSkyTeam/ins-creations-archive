    "xml": "from poemslib import *\n#1、修改程序循环次数，让程序出10道题目\n#2、补充代码，完成输入内容和正确答案不相等的情况\n# 请你修改程序循环次数，让程序出10道题目吧~\na = 0\nfor i in range(1):\n    print(question())\n    my = input(\"请输入答案：\")\n    ans = answer()\n    if my == ans:\n        print(\"恭喜你，答对了！\")\n    #=====================================================    \n    # 请你在第18行补充输入内容和正确答案不相等的情况：\n    # 请注意缩进格式哦~\n    if my != ans:\n        a = a + 1\n        print(\"很抱歉，答错了！正确答案是\",ans)\n        print(\"完整诗词为：\")\n        print(poem())\n    #====================================================\n    print(\"---------------------\")\nprint(\"你错了\",a,\"题\")\n#https://code.xueersi.com/space/13159581 老师看一下呗！！！！",
