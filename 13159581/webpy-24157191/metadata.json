    "xml": "#补充完整第7行、第24行和第29行代码，设计自己的娃娃机。\nfrom dolls_mach import *\n#补充完整第7行代码，设置娃娃机中的娃娃。\n#注意：图片名称是键，积分是值。\n#例如：dolls = {\"柠檬.png\":100}\n#作答区域。\ndolls = {\n    \"主讲.png\":5,\n    \"康静静.png\":543,\n    \"刘祥.png\":64,\n    \"王雪.png\":6456,\n    \"王立松.png\":5635,\n    \"柯南.png\":5645\n}\n\nset_dolls(dolls)\n\n#设置抓力，数字从1到10，数字越大，抓力越大。\nset_power(5)\n#设置爪子移动速度，数字越大，移动速度越快。\nset_speed(25)\n\nscore = 0\n\nwhile True:\n    key = catch()\n    if key != '':\n        #补充完整第24行代码（加号后内容），获取娃娃的积分。\n        #提示：字典中值的访问 字典名[键]\n        #作答区域。\n        score = score + doll[key]\n        show_score(score)\n        #补充完整第29行代码，取出成功抓到的娃娃。\n        #提示： del 字典名[键]\n        #作答区域。\n        del dolls[key]\n    #设置游戏时间，修改数字。\n    game_time(20)\n    play()",
    "lang": "webpy",
