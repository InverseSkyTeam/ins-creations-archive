    "thumbnail": "https://icourse.xesimg.com/programme/static/web/images/default-thumbnail-py.png",
    "xml": "#补充第26行代码，利用列表遍历的方法遍历列表p，生成p列表中障碍物位置\n#补充第41行代码，随机设置8个随机障碍\nfrom map import *\nfrom random import *\n#背景和形象设置\nbg(\"bg2.png\")            #可替换背景\nrole(\"王立松.png\")            #可替换成你喜欢的人物形象\nbarrier(\"barrier2.png\")  #可替换成你喜欢的障碍物形象\nreward(\"reward1.png\")    #可替换成你喜欢的宝箱形象\n\n#位置列表\npos = [\"a2\",\"a3\",\"a4\",\"a5\",\"a6\",\"a7\",\\\n    \"b1\",\"b2\",\"b3\",\"b4\",\"b5\",\"b6\",\"b7\",\\\n    \"c1\",\"c2\",\"c3\",\"c4\",\"c5\",\"c6\",\"c7\",\\\n    \"d1\",\"d2\",\"d3\",\"d4\",\"d5\",\"d6\",\"d7\",\\\n    \"e1\",\"e2\",\"e3\",\"e4\",\"e5\",\"e6\",\"e7\",\\\n    \"f1\",\"f2\",\"f3\",\"f4\",\"f5\",\"f6\",\"f7\",\\\n    \"g1\",\"g2\",\"g3\",\"g4\",\"g5\",\"g6\"]\n    \n########################################\nlevel(1) #第一关\n\n#设置障碍物位置（下面障碍物的可以增加、删减或者修改）\np = [\"b1\",\"d3\",\"e3\",\"f3\",\"a4\",\"b4\",\"c4\",\"d4\",\"a6\",\"d6\",\"e6\",\"f6\",\"g6\"]\n\n#补充第26行代码，利用列表遍历的方法遍历列表p，生成p列表中障碍物位置\nfor i in p:\n    bpos(i)\n\n#设置宝箱位置（下面宝箱的可以增加、删减或者修改）   \nr = [\"c2\",\"d2\",\"e7\",\"b6\"]\nfor i in r:\n    rpos(i)\n\n#enemy(1)  #可以增加、减少敌人的数量\n\n#################################\nlevel(2)  #第2关\n\n\n#补充第41行代码，随机设置8个随机障碍物\nfor i in range(8):\n    t = choice(pos)      #从位置列表中随机选取一个位置\n    bpos(t)\n\n#设置宝箱位置（下面宝箱的可以增加、删减或者修改）          \nr = [\"c6\",\"c6\",\"d2\",\"g6\"]\nfor i in r:\n    rpos(i)\n\nenemy(1) #可以增加、减少敌人的数量\n\n################################\nlevel(3) #第3关\n\n#设置障碍物位置（下面障碍物的可以增加、删减或者修改）\np = [\"f1\",\"b3\",\"f3\",\"b4\",\"c4\",\"d5\",\"f4\",\"b5\",\"f5\",\"d6\",\"g6\",\"d7\"]\nfor i in p:\n    bpos(i)\n\n#设置宝箱位置（下面障碍物的可以增加、删减或者修改）    \nr = [\"e5\",\"f6\"]\nfor i in r:\n    rpos(i)\n\nenemy(1) #可以增加、减少敌人的数量\n\n########################################\n\n#启动游戏\nplay()",
