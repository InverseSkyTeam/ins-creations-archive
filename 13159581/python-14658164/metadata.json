    "xml": "print(\"欢迎来到数学王国，古诗题的挑战马上开始~\")\nprint(\"李白沽酒探亲朋，路途迢迢有六程。\")\nprint(\"行至一程多一倍，却被书童喝四升。\")\nprint(\"行到亲朋家里面，半点全无在酒瓶。\")\nprint(\"借问高朋能算士，几何原酒要分明。\")\nprint(\"限时三分钟，请你完成代码，算出结果\")\n\nwine = 0\n#1、修改程序中的参数，注意上面诗中的关键信息，完成计算~\nfor i in range(6):\n#在下面补充代码，（被疏通喝掉四升）表示酒量增加4升\n    wine = wine + 4\n    wine = wine / 2\nprint(wine)",
