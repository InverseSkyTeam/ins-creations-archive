    "xml": "from time import *\nfrom xes.ext import *\na = input(\"请输入你要倒计时的时间（s）：\")\nb = int(a)\nclass a:\n    def b(self):\n        self.b = localtime()\n        print(\"计时开始...\")\n    def c(self):\n        self.c = localtime()\n        self._calc()\n        print(\"计时结束！\")\n    def _calc(self):\n        self.lasted = []\n        self.prompt = \"总共运行了\"\n        for i in range(6):\n            self.lasted.append(self.c[i] - self.b[i])\n            self.prompt += str(self.lasted[i])\n        print(self.prompt)\nz = a()\nz.b()\nsleep(b)\nz.c()\nplay_mp3(\"baba.mp3\")",
