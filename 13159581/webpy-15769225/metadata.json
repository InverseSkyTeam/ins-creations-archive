    "xml": "#请按照下列步骤完成题目\nfrom turtle import *\n#1、选择自己喜欢的图片作为题目，修改下面的代码\nScreen().bgpic(\"自拍.png\")\nans = input(\"请输入回答：\")\n#2、结合自己选择的图片，补充等于正确答案的条件\nif ans == \"自拍\":\n    print(\"恭喜你，答对了！ \")\n#3、补充代码，实现回答错误的效果\nelse:\n    print(\"对不起，你答错了\")\n#4、拓展：还可以试着多出几道题哟~\n\nScreen().bgpic(\"千手观音.png\")\nans = input(\"请输入回答：\")\nif ans == \"千手观音\":\n    print(\"恭喜你，答对了！ \")\nelse:\n    print(\"对不起，你答错了\")\n\nScreen().bgpic(\"吃瓜群众.png\")\nans = input(\"请输入回答：\")\nif ans == \"吃瓜群众\":\n    print(\"恭喜你，答对了！ \")\nelse:\n    print(\"对不起，你答错了\")\n\nScreen().bgpic(\"五花八门.png\")\nans = input(\"请输入回答：\")\nif ans == \"五花八门\":\n    print(\"恭喜你，答对了！ \")\nelse:\n    print(\"对不起，你答错了\")\n\nScreen().bgpic(\"鲍鱼.png\")\nans = input(\"请输入回答：\")\nif ans == \"鲍鱼\":\n    print(\"恭喜你，答对了！ \")\nelse:\n    print(\"对不起，你答错了\")\n\nScreen().bgpic(\"翅膀.png\")\nans = input(\"请输入回答：\")\nif ans == \"翅膀\":\n    print(\"恭喜你，答对了！ \")\nelse:\n    print(\"对不起，你答错了\")\n\nScreen().bgpic(\"尔康.png\")\nans = input(\"请输入回答：\")\nif ans == \"尔康\":\n    print(\"恭喜你，答对了！ \")\nelse:\n    print(\"对不起，你答错了\")\n    \nScreen().bgpic(\"熊掌.png\")\nans = input(\"请输入回答：\")\nif ans == \"熊掌\":\n    print(\"恭喜你，答对了！ \")\nelse:\n    print(\"对不起，你答错了\")",
