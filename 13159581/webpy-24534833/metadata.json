    "xml": "from xes_flipcard import *\nfrom  random import *\n\n# 定义卡牌\ncards = [\n    {\"图片\": \"五六七.png\", \"状态\":\"反\"},\n    {\"图片\": \"悟空.png\", \"状态\":\"反\"},\n    {\"图片\": \"小黄鸭.png\", \"状态\":\"反\"},\n    {\"图片\": \"李白.png\", \"状态\":\"反\"},\n    {\"图片\": \"迪迦.png\", \"状态\":\"反\"},\n    {\"图片\": \"柯南.png\", \"状态\":\"反\"},\n    {\"图片\": \"小舞.png\", \"状态\":\"反\"},\n    {\"图片\": \"唐三.png\", \"状态\":\"反\"},\n    {\"图片\": \"五六七.png\", \"状态\":\"反\"},\n    {\"图片\": \"悟空.png\", \"状态\":\"反\"},\n    {\"图片\": \"小黄鸭.png\", \"状态\":\"反\"},\n    {\"图片\": \"李白.png\", \"状态\":\"反\"},\n    {\"图片\": \"迪迦.png\", \"状态\":\"反\"},\n    {\"图片\": \"柯南.png\", \"状态\":\"反\"},\n    {\"图片\": \"小舞.png\", \"状态\":\"反\"},\n    {\"图片\": \"唐三.png\", \"状态\":\"反\"}\n]\n# 打乱卡牌顺序\nshuffle(cards)\n\n# 设置游戏卡牌\nset_cards(cards)\n\n# 循环进行游戏\nwhile True:\n    # 翻一张\n    a = click()\n    #作答区域，补充第一次点击实现翻转的代码\n    cards[a][\"状态\"] = \"正\"\n    show()\n    \n     # 翻两张\n    b = click()\n    #作答区域，补充第二次点击实现翻转的代码\n    cards[b][\"状态\"] = \"正\"\n    show()\n    \n    # 判断卡片是都匹配，直到游戏结束\n    match(a,b)",
