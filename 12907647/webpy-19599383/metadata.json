    "thumbnail": "https://livefile.xesimg.com/programme/assets/5d831ef6276a8cd3004cfbe2c13e884c.jpg",
    "xml": "from random import *\nfrom superball import *\n\n# ————————挑战一 超级英雄——————————————————\n# 修改球球的图片，移动速度，初始大小，长大的速度grow\n# ——————————————————————————————————————————\n# 修改球球的图片（查看左边素材区，换为对应图片名字即可）\nh = \"hero1.png\"  \n# 修改球球的移动速度\nhspeed = 10\n# 修改球球的大小\nhscale = 50\n# 修改球球长大的速度\ngrow = 10\n\n\n\n# ————————挑战二 克敌制胜——————————————————\n# 修改敌人出现的频率ef，移动的速度，初始大小\n# ——————————————————————————————————————————\n# 修改ef, 出现新敌人需要等待的时间，数字越小，出现越快 \nef = 30\n\ndef random_speed():\n    # 修改speedx的值, 可以修改敌人的横向移动速度\n    speedx = randint(-1, 1) \n    # 修改speedy的值, 可以修改敌人的纵向移动速度\n    speedy = randint(-1, 1)  \n    return speedx, speedy\n\ndef random_scale():\n    # 修改scale的值, 可以修改敌人的大小\n    scale = randint(15, 200) \n    return scale\n\n\n\n# ————————挑战三 释放“大招”——————————————\n# 游戏有三个大招, 清屏炸弹, 增加时间，巨人蘑菇\n# 修改大招出现的频率和大招的效果\n# ——————————————————————————————————————————\n# 修改sf，新大招出现前等待时间，数字越小，出现越快\nsf = 100  \n# 修改add_time, 控制吃掉时间武器时增加的时长\nadd_time = 5  \n# 修改add_scale, 控制吃掉巨人蘑菇后长大的尺寸（负数减小）\nadd_scale = 30\n\n\n\n# ————————挑战四 化身“得分王”——————————————\n# 修改每次得分的数量\n# ——————————————————————————————————————————\n# 修改sp，控制每次得分的数量\nsp = 100\n\n\n\n# ————————挑战五 精益求精——————————————————\n# 控制背景图片bgimg\n# 背景音乐的选择bgm\n# ——————————————————————————————————————————\n# 修改背景图片(可换为bg1\\bg2\\bg3)\nbgimg = \"bg2.png\"  \n# 修改背景音乐文件（可换为bgm1\\bgm2）\nbgm = \"bgm1.wav\"  \n\n\n\n\n\n\n\n\n\n\n\nstart(h, hspeed, hscale, grow, ef, random_speed, random_scale, sf, sp, bgimg, bgm, add_time, add_scale)\n",
