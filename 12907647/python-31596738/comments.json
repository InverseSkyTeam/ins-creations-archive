                {
                    "id": 2366102,
                    "topic_id": "CP_31596738",
                    "parent_id": 2327846,
                    "target_id": 2365897,
                    "user_id": "17025146",
                    "reply_user_id": "12907647",
                    "content": "前进、后退、刷新网页都是逻辑层面的了，不再是API层面，你可以用一个列表记录下每个访问的网址，后退的时候就相当于是访问上一个网址，前进同理，刷新相当于再访问一次当前网址，好像没什么难的吧。如果上述方法不行，就试试cef的注入js代码，应该可以成功实现刷新，而且webview和其他的比起来很特殊，它可以包装flask应用，对你说的这些支持应该是很好了",
                    "likes": 0,
                    "unlikes": 0,
                    "replies": 0,
                    "top": 0,
                    "removed": 0,
                    "links": null,
                    "created_at": "2022-03-20 20:13:12",
