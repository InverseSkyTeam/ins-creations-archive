    "xml": "#include<iostream>\nusing namespace std;\n\nint main(){\n    int L,is_prime,n=1,total=0,totalL=0;\n    cin >> L;\n    while (totalL+n<L){\n        n++;\n        is_prime = 1;\n        for (int i=2;i<=n;i++){\n            if (n%i==0 && i!=1 && i!=n){\n                is_prime = 0;\n                break;\n            }\n        }\n        if (is_prime){\n            totalL += n;\n            total++;\n            cout << n << endl;\n        }\n    }\n    cout << total;\n    return 0;\n}",
