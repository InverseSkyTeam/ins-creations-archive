    "xml": "print('首页上的阶乘太水了，算不满17，C++算法果然菜，还是py来解决吧(py输入50000多都没问题(5秒)，每算10000多算1秒，多输出2.58秒)')\nprint('-'*60)\nwhile True:\n    try:\n        n = int(input('输入n，将要阶乘至n'))\n    except:\n        product = '输入有误'\n    else:\n        product = 1\n        if n > 0:\n            for i in range(1,n+1):\n                product *= i\n    finally:\n        print('答案是\\033[1;32m{}\\033[0m，可继续输入'.format(product))\n        input('回车继续')\n        print('\\033[100A\\033[2J\\033[100A\\033[3J')",
