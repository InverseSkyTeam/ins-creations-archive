    "xml": "from holiday import *\nmusic(\"a.mp3\")\ndef m(t1,t2):\n    text(t1)\n    t(t2)\nm('国庆节到了，我们愉快的假期有8天',3)\nm('国庆节中不可或缺的东西就是',1)\nm('国庆节中不可或缺的东西就是',1)\nm('那阅兵仪式',1)\nm('全家一起看阅兵',2)\nm('就好极了！',2)\nimg(\"11.png\")\nt(3)\nm(\"看到军人叔叔整齐划一的身影\",2)\nm(\"我感到他们就是我的榜样\",1)\nm(\"我感到他们就是我的榜样\",1)\nm(\"我感到他们就是我的榜样\",1)\nm(\"和国庆同一天的是中秋节\",2)\nm(\"中秋的时候\",1)\nm(\"我和爸爸妈妈爷爷奶奶一起吃了饭,月饼\",5)\nimg(\"12.png\")\nt(3)\nm(\"一起运动\",2)\nimg(\"13.png\")\nt(3)\nm(\"一起赏月\",2)\nm(\"拿着望远镜寻星\",2)\nm(\"耶！！！！！！！~~~\",1)\nm(\"耶！！！！！！！~~~\",1)\nm(\"耶！！！！！！！~~~\",1)\nm(\"最后\",1)\nm(\"祝\",1)\nm(\"大家\",1)\nm(\"国庆节快乐！！！~~~\",5)\nshow()",
