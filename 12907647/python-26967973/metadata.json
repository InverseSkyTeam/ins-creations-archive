    "xml": "from time import *\nimport random\nx = time()\n10**10**6\nprint('你的电脑计算10^10^6的用时是约\\033[1;32m',round(time()-x,2),'\\033[0m秒')\nx = time()\nprint('你的电脑计算1+2+3+...+1000’0000的结果为\\033[1;32m',sum(range(1,10000000),2),'\\033[0m用时是约\\033[1;32m',round(time()-x,2),'\\033[0m秒')\nx = time()\nfor i in range(100000000):pass\nprint('你的电脑执行一亿次空循环的用时是约\\033[1;32m',round(time()-x,2),'\\033[0m秒')\nx = time()\\nx2 = time()\nprint('你的电脑阅读1次数字(2x10^1000)的用时是约\\033[1;32m',round(x2-x,5),'\\033[0m秒')\nx = time()\nprint('\\033[33mhello.I am a computer.\\033[0m')\nprint('你的电脑输出1次以上内容的用时是约\\033[1;32m',round(time()-x,4),'\\033[0m秒')\nx = time()\nfor i in range(3):\n    import pygame\n    pygame.init()\n    pygame.quit()\n    del pygame\nprint('你的电脑运行3次[导库、初始化、退出、删除库]的用时是约\\033[1;32m',round(time()-x,2),'\\033[0m秒')\nx = time()\nfor i in range(1000000):\n    random.randint(10,1000)\nprint('你的电脑运行100w次[10~1000选择随机数运算]的用时是约\\033[1;32m',round(time()-x,2),'\\033[0m秒')\nx = time()\nfor i in range(10000000):\n    1+1\nprint('你的电脑运行1000w次1+1的用时是约\\033[1;32m',round(time()-x,2),'\\033[0m秒')",
