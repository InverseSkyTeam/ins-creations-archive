    "xml": "class Queue(list):\n    def push(self,x):\n        self.append(x)\n    def empty(self):\n        return not self\n    def front(self):\n        return self[0]\n    def pop(self):\n        del self[0]\nqueue = Queue()\nprint(queue.empty())\nqueue.push(1)\nqueue.push(2)\nqueue.push(3)\nqueue.pop()\nprint(queue,queue.front(),sep='\\n')\nprint('c++ bfs queue 魔怔')",
