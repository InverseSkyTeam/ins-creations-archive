    "xml": "from turtle import *\nspeed(0)\n# 内角和=(x-2)*180/x\n# 则内角=180-360/x\n# 则外角=360/x\n\nprint('绘制正x边形\\n输入x:')\nx = float(input())\nif -1 <= x <= 1:\n    raise SystemExit('此时这个图形的面积为无穷大，无法绘制')\nprint('请注意任务栏是否弹出窗口')\nalpha = 360 / x\n\nif int(x) == x:\n    length = 500/x\nelse:\n    length = 200\n\ndid = 0\nwhile (distance(0,0) > 0.001) or (not did):   # 回到原点\n    did = 1\n    forward(length)\n    right(alpha)\n\nprint('完成正',x,'变形的绘制')\ndone()",
